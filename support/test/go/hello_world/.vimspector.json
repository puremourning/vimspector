{
  "configurations": {
    "golang-run": {
      "adapter": "vscode-go",
      "configuration": {
        "request": "launch",
        "program": "${workspaceRoot}/hello-world.go",
        "mode": "debug",
        "dlvToolPath": "$HOME/go/bin/dlv",
        "trace": true,
        "env": { "GO111MODULE": "off" }
      }
    },
    "golang-attach": {
      "adapter": "vscode-go",
      "configuration": {
        "request": "attach",
        "dlvToolPath": "$HOME/go/bin/dlv",
        "mode": "local",
        "cwd": "${workspaceRoot}",
        "processId": "${pid:}"
      }
    }
  }
}
